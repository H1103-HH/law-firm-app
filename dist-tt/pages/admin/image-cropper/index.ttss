.image-cropper-page{min-height:100vh;background:#f5f5f5;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column}.navbar{height:44rpx;background:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;padding:0 16rpx;-webkit-box-shadow:0 2rpx 8rpx rgba(0,0,0,.05);box-shadow:0 2rpx 8rpx rgba(0,0,0,0.05098);position:fixed;top:0;left:0;right:0;z-index:100}.navbar-btn{background:transparent;border:none;padding:8rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.navbar-btn.disabled{opacity:.5}.navbar-title{font-size:18rpx;font-weight:600;color:#333}.cropper-container{-webkit-flex:1;-ms-flex:1;flex:1;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding:60rpx 20rpx 20rpx;overflow:hidden}.cropper-area{width:300rpx;height:300rpx;background:#000;border-radius:16rpx;overflow:hidden;position:relative;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}.cropper-canvas{position:absolute;top:0;left:0;width:300rpx;height:300rpx;opacity:0;pointer-events:none}.cropper-image{max-width:100%;max-height:100%;-webkit-transition:-webkit-transform .1s ease;transition:-webkit-transform .1s ease;transition:transform .1s ease;transition:transform .1s ease, -webkit-transform .1s ease;-ms-touch-action:none;touch-action:none;pointer-events:none}.image-wrapper{-ms-touch-action:none;touch-action:none;cursor:-webkit-grab;cursor:grab}.image-wrapper:active,.cropper-image:active{cursor:-webkit-grabbing;cursor:grabbing}.cropper-image.rotated{-webkit-transition:-webkit-transform .3s ease;transition:-webkit-transform .3s ease;transition:transform .3s ease;transition:transform .3s ease, -webkit-transform .3s ease}.crop-box{position:absolute;top:50%;left:50%;-webkit-transform:translate(-50%,-50%);-ms-transform:translate(-50%,-50%);transform:translate(-50%,-50%);width:200rpx;height:200rpx;border:2rpx solid rgba(255,255,255,.8);border-radius:50%;overflow:hidden;pointer-events:none;z-index:10}.crop-border{position:absolute;width:20rpx;height:20rpx;border:3rpx solid #1890ff;border-radius:50%;z-index:11}.crop-border.top-left{top:-10rpx;left:-10rpx;border-right:none;border-bottom:none;background:#1890ff}.crop-border.top-right{top:-10rpx;right:-10rpx;border-left:none;border-bottom:none;background:#1890ff}.crop-border.bottom-left{bottom:-10rpx;left:-10rpx;border-right:none;border-top:none;background:#1890ff}.crop-border.bottom-right{bottom:-10rpx;right:-10rpx;border-left:none;border-top:none;background:#1890ff}.crop-grid{position:absolute;top:0;right:0;bottom:0;left:0;z-index:11}.grid-line{position:absolute;background:rgba(255,255,255,.3)}.grid-line.horizontal-1{top:33.33%;left:0;right:0;height:1rpx}.grid-line.horizontal-2{top:66.66%;left:0;right:0;height:1rpx}.grid-line.vertical-1{left:33.33%;top:0;bottom:0;width:1rpx}.grid-line.vertical-2{left:66.66%;top:0;bottom:0;width:1rpx}.cropper-hint{margin-top:16rpx;padding:0 20rpx}.hint-text{font-size:14rpx;color:#666;text-align:center;line-height:1.5}.cropper-controls{background:#fff;padding:20rpx;border-top:1rpx solid #e0e0e0}.control-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;gap:16rpx;margin-bottom:16rpx}.control-row:last-child{margin-bottom:0}.control-label{font-size:14rpx;color:#333;min-width:40rpx}.control-btn{-webkit-flex:1;-ms-flex:1;flex:1;background:#f5f5f5;border:none;border-radius:8rpx;padding:12rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;gap:4rpx}.btn-text{font-size:12rpx;color:#333}.control-slider{-webkit-flex:1;-ms-flex:1;flex:1}
