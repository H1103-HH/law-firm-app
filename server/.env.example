# Node 环境
NODE_ENV=production

# 服务端口（默认 3000）
PORT=3000

# Supabase 数据库配置
# 注意：项目中使用 COZE_SUPABASE_URL 和 COZE_SUPABASE_ANON_KEY

# 1. 登录 https://supabase.com/
# 2. 进入你的项目
# 3. 点击 Settings -> API
# 4. 复制以下信息到对应字段

# Supabase 项目 URL
COZE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key（用于前端访问）
COZE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 数据库连接字符串（用于后端连接数据库）
# 格式: postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# 对象存储配置（可选，如果使用其他 S3 兼容存储）
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
